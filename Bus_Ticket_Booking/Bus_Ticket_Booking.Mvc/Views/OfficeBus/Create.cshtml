@model Bus_Ticket_Booking.Mvc.ViewModels.Bus.CreateBusViewModel

@{
    ViewData["Title"] = "Create Bus";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow border-0">

                <div class="card-body p-5">

                    <h2 class="text-primary mb-4">

                        Create Bus

                    </h2>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">

                            @ViewBag.Error

                        </div>
                    }

                    <form asp-action="Create"
                          method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <!-- REGISTRATION NUMBER -->

                        <div class="mb-3">

                            <label class="form-label">

                                Registration Number

                            </label>

                            <input asp-for="RegistrationNumber"
                                   class="form-control"
                                   placeholder="Enter registration number" />

                            <span asp-validation-for="RegistrationNumber"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- CAPACITY -->

                        <div class="mb-3">

                            <label class="form-label">

                                Capacity

                            </label>

                            <input asp-for="Capacity"
                                   type="number"
                                   min="1"
                                   class="form-control"
                                   placeholder="Enter bus capacity" />

                            <span asp-validation-for="Capacity"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- BUS TYPE -->

                        <div class="mb-4">

                            <label class="form-label">

                                Bus Type

                            </label>

                            <select asp-for="Type"
                                    asp-items="Model.BusTypes"
                                    class="form-select">

                                <option value="">
                                    -- Select Bus Type --
                                </option>

                            </select>

                            <span asp-validation-for="Type"
                                  class="text-danger">
                            </span>

                        </div>

                        <button type="submit"
                                class="btn btn-success w-100">

                            Create Bus

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial");
    }
}