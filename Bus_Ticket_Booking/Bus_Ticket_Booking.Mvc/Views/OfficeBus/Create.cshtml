@model Bus_Ticket_Booking.Mvc.ViewModels.Bus.CreateBusViewModel

@{
    ViewData["Title"] = "Create Bus";
}

<div class="container py-5">

    <div class="card shadow-sm border-0">

        <div class="card-body p-5">

            <h2 class="text-primary mb-4">

                Create Bus

            </h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">

                    @ViewBag.Error

                </div>
            }

            <form asp-action="Create"
                  method="post">

                <div class="mb-3">

                    <label class="form-label">

                        Registration Number

                    </label>

                    <input asp-for="RegistrationNumber"
                           class="form-control" />

                    <span asp-validation-for="RegistrationNumber"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label class="form-label">

                        Capacity

                    </label>

                    <input asp-for="Capacity"
                           class="form-control" />

                    <span asp-validation-for="Capacity"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label class="form-label">

                        Bus Type

                    </label>

                    <select asp-for="Type"
                            asp-items="Model.BusTypes"
                            class="form-select">

                        <option value="">
                            -- Select Bus Type --
                        </option>

                    </select>

                    <span asp-validation-for="Type"
                          class="text-danger"></span>

                </div>

                <button type="submit"
                        class="btn btn-success w-100">

                    Create Bus

                </button>

            </form>

        </div>

    </div>

</div>