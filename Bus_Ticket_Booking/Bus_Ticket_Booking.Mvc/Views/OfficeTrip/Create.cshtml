@model Bus_Ticket_Booking.Mvc.ViewModels.Trip.CreateTripViewModel

@{
    ViewData["Title"] = "Create Trip";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-md-10">

            <div class="card shadow border-0">

                <div class="card-body p-5">

                    <h2 class="text-primary mb-4">

                        Create Trip

                    </h2>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Create"
                          method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="row">

                            <!-- ROUTE -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Route
                                </label>

                                <select asp-for="RouteId"
                                        asp-items="Model.Routes"
                                        class="form-select">

                                    <option value="">
                                        Select Route
                                    </option>

                                </select>

                                <span asp-validation-for="RouteId"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- BUS -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Bus
                                </label>

                                <select asp-for="BusId"
                                        asp-items="Model.Buses"
                                        class="form-select">

                                    <option value="">
                                        Select Bus
                                    </option>

                                </select>

                                <span asp-validation-for="BusId"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- BOARDING -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Boarding Address
                                </label>

                                <select asp-for="BoardingAddressId"
                                        asp-items="Model.Addresses"
                                        class="form-select">

                                    <option value="">
                                        Select Boarding Address
                                    </option>

                                </select>

                                <span asp-validation-for="BoardingAddressId"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- DROPPING -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Dropping Address
                                </label>

                                <select asp-for="DroppingAddressId"
                                        asp-items="Model.Addresses"
                                        class="form-select">

                                    <option value="">
                                        Select Dropping Address
                                    </option>

                                </select>

                                <span asp-validation-for="DroppingAddressId"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- DRIVER 1 -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Driver 1
                                </label>

                                <select asp-for="Driver1DriverId"
                                        asp-items="Model.Drivers"
                                        class="form-select">

                                    <option value="">
                                        Select Driver
                                    </option>

                                </select>

                                <span asp-validation-for="Driver1DriverId"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- DRIVER 2 -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Driver 2
                                </label>

                                <select asp-for="Driver2DriverId"
                                        asp-items="Model.Drivers"
                                        class="form-select">

                                    <option value="">
                                        Select Driver
                                    </option>

                                </select>

                                <span asp-validation-for="Driver2DriverId"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- DEPARTURE -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Departure Time
                                </label>

                                <input asp-for="DepartureTime"
                                       type="datetime-local"
                                       class="form-control" />

                                <span asp-validation-for="DepartureTime"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- ARRIVAL -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Arrival Time
                                </label>

                                <input asp-for="ArrivalTime"
                                       type="datetime-local"
                                       class="form-control" />

                                <span asp-validation-for="ArrivalTime"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- FARE -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Fare
                                </label>

                                <input asp-for="Fare"
                                       class="form-control" />

                                <span asp-validation-for="Fare"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- TRIP DATE -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Trip Date
                                </label>

                                <input asp-for="TripDate"
                                       type="date"
                                       class="form-control" />

                                <span asp-validation-for="TripDate"
                                      class="text-danger">
                                </span>

                            </div>

                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100 mt-3">

                            Create Trip

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial");
    }
}