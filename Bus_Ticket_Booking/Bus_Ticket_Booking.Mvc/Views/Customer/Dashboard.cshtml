@using Bus_Ticket_Booking.Mvc.Helpers

@{
    ViewData["Title"] = "Customer Dashboard";

    var email = Context.Session.GetString(SessionKeys.Email);
}

<div class="container py-5">

    <div class="row">

        <div class="col-md-12">

            <div class="card custom-card p-5">

                <div class="d-flex
                    justify-content-between
                    align-items-center">

                    <div>

                        <h1 class="text-primary">

                            Welcome Customer

                        </h1>

                        <p class="text-muted">

                            @email

                        </p>

                    </div>

                    <div>

                        <i class="bi bi-person-circle
                            display-2 text-primary">
                        </i>

                    </div>

                </div>

                <hr />

                <div class="row mt-4">


                    <!-- MY BOOKINGS -->

                    <div class="col-md-3 mb-4">

                        <a asp-controller="Booking"
                               asp-action="MyBookings"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100 dashboard-card">

                                <div class="card-body">

                                    <i class="bi bi-ticket-perforated
                                        display-5 text-primary">
                                    </i>

                                    <h4 class="mt-3 text-dark">

                                        My Bookings

                                    </h4>

                                    <p class="text-muted">

                                        View all bookings

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- PAYMENTS -->

                    <div class="col-md-3 mb-4">

                        <a asp-controller="Payment"
                               asp-action="MyPayments"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100 dashboard-card">

                                <div class="card-body">

                                    <i class="bi bi-credit-card
                                        display-5 text-success">
                                    </i>

                                    <h4 class="mt-3 text-dark">

                                        Payments

                                    </h4>

                                    <p class="text-muted">

                                        Payment history

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- SEARCH TRIPS -->

                    <div class="col-md-3 mb-4">

                        <a asp-controller="Trip"
                               asp-action="Index"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100 dashboard-card">

                                <div class="card-body">

                                    <i class="bi bi-bus-front
                                        display-5 text-danger">
                                    </i>

                                    <h4 class="mt-3 text-dark">

                                        Search Trips

                                    </h4>

                                    <p class="text-muted">

                                        Find buses

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- MY REVIEWS -->

                    <div class="col-md-3 mb-4">

                        <a asp-controller="Review"
                               asp-action="MyReviews"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100 dashboard-card">

                                <div class="card-body">

                                    <i class="bi bi-star-fill
                                        display-5 text-warning">
                                    </i>

                                    <h4 class="mt-3 text-dark">

                                        My Reviews

                                    </h4>

                                    <p class="text-muted">

                                        View & manage reviews

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- PROFILE -->

                    <div class="col-md-3 mb-4">

                        <a asp-controller="Customer"
                               asp-action="Profile"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100 dashboard-card">

                                <div class="card-body">

                                    <i class="bi bi-person-lines-fill
                                        display-5 text-warning">
                                    </i>

                                    <h4 class="mt-3 text-dark">

                                        My Profile

                                    </h4>

                                    <p class="text-muted">

                                        Manage address/profile

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                </div>

            </div>

        </div>

    </div>

</div>
</div>