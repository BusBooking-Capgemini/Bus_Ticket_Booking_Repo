@{
    ViewData["Title"] = "Booking Success";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card custom-card p-5 text-center">

                <i class="bi bi-check-circle-fill
                    text-success"
                       style="font-size:70px;">
                </i>

                <h2 class="mt-4 text-success">

                    Booking Confirmed

                </h2>

                <p class="mt-3">

                    Your booking was created
                    successfully.

                </p>

                <h5 class="mt-3">

                    Booking ID:
                    @ViewBag.BookingId

                </h5>

                <a asp-controller="Trip"
                       asp-action="Index"
                       class="btn btn-primary mt-4">

                    Book More Trips

                </a>

            </div>

        </div>

    </div>

</div>