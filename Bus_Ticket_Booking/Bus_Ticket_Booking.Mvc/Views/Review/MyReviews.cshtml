@model List<Bus_Ticket_Booking.Mvc.ViewModels.Review.ReviewViewModel>

@{
    ViewData["Title"] = "My Reviews";
}

<div class="container py-4">

    <!-- HEADER -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-warning mb-1">

                My Reviews

            </h2>

            <p class="text-muted mb-0">

                Reviews you have left for your trips

            </p>

        </div>

        <div class="bg-warning bg-opacity-10 p-3 rounded-circle">

            <i class="bi bi-star-fill text-warning fs-4"></i>

        </div>

    </div>


    <!-- SUCCESS ALERT -->

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">

            <i class="bi bi-check-circle me-2"></i>

            @TempData["SuccessMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }


    <!-- ADD REVIEW PROMPT -->

    <div class="alert alert-info d-flex align-items-center gap-3 mb-4 border-0 rounded-4">

        <i class="bi bi-info-circle fs-5"></i>

        <span>
            To add a review for a trip, go to
            <a asp-controller="Booking"
               asp-action="MyBookings"
               class="fw-semibold alert-link">
                My Bookings
            </a>
            and click <strong>Write a Review</strong> on any completed trip.
        </span>

    </div>


    <!-- REVIEWS TABLE -->

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">

                        <tr>
                            <th>Route</th>
                            <th>Trip ID</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            @foreach (var review in Model)
                            {
                                <tr>

                                    <td class="fw-semibold">

                                        @review.FromCity → @review.ToCity

                                    </td>

                                    <td class="text-muted">

                                        #@review.TripId

                                    </td>

                                    <td>

                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star text-secondary"></i>
                                            }
                                        }

                                        <span class="ms-1 text-muted small">(@review.Rating/5)</span>

                                    </td>

                                    <td class="text-muted" style="max-width:280px;">

                                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                                        {
                                            <span class="text-truncate d-inline-block"
                                                  style="max-width:260px;"
                                                  title="@review.Comment">
                                                @review.Comment
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="fst-italic text-muted">No comment</span>
                                        }

                                    </td>

                                    <td class="text-muted">

                                        @(review.ReviewDate.HasValue
                                            ? review.ReviewDate.Value.ToString("dd MMM yyyy")
                                            : "—")

                                    </td>

                                    <td>

                                        <form asp-action="Delete"
                                              method="post">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="reviewId"
                                                   value="@review.ReviewId" />

                                            <button type="submit"
                                                    class="btn btn-outline-danger btn-sm"
                                                    onclick="return confirm('Delete this review?')">

                                                <i class="bi bi-trash me-1"></i>Delete

                                            </button>

                                        </form>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="6"
                                    class="text-center py-5 text-muted">

                                    <i class="bi bi-star fs-1 d-block mb-3 text-warning opacity-50"></i>

                                    You haven't left any reviews yet.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>
