@model Bus_Ticket_Booking.Mvc.ViewModels.AgencyDashboard.AgencyDashboardViewModel

@{
    ViewData["Title"] = "Agency Dashboard";
}

<div class="container py-4">

    <!-- HEADER -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold text-primary mb-1">

                @Model.Name

            </h1>

            <p class="text-muted mb-1">

                <i class="bi bi-person-circle me-1"></i>

                @Model.ContactPersonName

            </p>

            <p class="text-muted mb-1">

                <i class="bi bi-envelope me-1"></i>

                @Model.Email

            </p>

            <p class="text-muted mb-0">

                <i class="bi bi-telephone me-1"></i>

                @Model.Phone

            </p>

        </div>

    </div>


    <!-- TOP CARDS -->

    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">

                                Total Offices

                            </p>

                            <h2 class="fw-bold text-primary mb-0">

                                @Model.TotalOffices

                            </h2>

                        </div>

                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-buildings text-primary fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">

                                Total Bookings

                            </p>

                            <h2 class="fw-bold text-success mb-0">

                                @Model.TotalBookings

                            </h2>

                        </div>

                        <div class="bg-success bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-ticket-perforated text-success fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">

                                Total Payments

                            </p>

                            <h2 class="fw-bold text-dark mb-0">

                                @Model.TotalPayments

                            </h2>

                        </div>

                        <div class="bg-dark bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-credit-card text-dark fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">

                                Revenue

                            </p>

                            <h2 class="fw-bold text-warning mb-0">

                                ₹@Model.TotalRevenue

                            </h2>

                        </div>

                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-currency-rupee text-warning fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>


    <!-- ANALYTICS -->

    <div class="row g-4 mb-5">

        <!-- BOOKING ANALYTICS -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <h4 class="fw-bold mb-0">

                            Booking Analytics

                        </h4>

                        <i class="bi bi-bar-chart-line text-primary fs-4"></i>

                    </div>

                    <!-- OCCUPANCY -->

                    <div class="mb-4">

                        <div class="d-flex justify-content-between mb-2">

                            <span class="fw-semibold">

                                Occupancy Rate

                            </span>

                            <span class="fw-bold text-primary">

                                @Model.OccupancyRate%

                            </span>

                        </div>

                        <div class="progress" style="height:10px;">

                            <div class="progress-bar bg-primary"
                                 style="width:@Model.OccupancyRate%">
                            </div>

                        </div>

                    </div>

                    <div class="mb-3">

                        <p class="text-muted mb-1">

                            Active Bookings

                        </p>

                        <h5 class="fw-bold">

                            @Model.ActiveBookings

                        </h5>

                    </div>

                    <div class="mb-3">

                        <p class="text-muted mb-1">

                            Most Booked Trip

                        </p>

                        <h5 class="fw-bold">

                            Trip #@Model.MostBookedTripId

                        </h5>

                    </div>

                    <div>

                        <p class="text-muted mb-1">

                            Popular Route

                        </p>

                        <h5 class="fw-bold text-success">

                            @Model.MostPopularRoute

                        </h5>

                    </div>

                </div>

            </div>

        </div>


        <!-- PAYMENT ANALYTICS -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <h4 class="fw-bold mb-0">

                            Payment Analytics

                        </h4>

                        <i class="bi bi-graph-up-arrow text-success fs-4"></i>

                    </div>

                    <div class="row mb-4">

                        <div class="col-6">

                            <div class="bg-success bg-opacity-10 rounded-4 p-3 text-center">

                                <h3 class="fw-bold text-success">

                                    @Model.SuccessRate%

                                </h3>

                                <small class="text-muted">

                                    Success Rate

                                </small>

                            </div>

                        </div>

                        <div class="col-6">

                            <div class="bg-danger bg-opacity-10 rounded-4 p-3 text-center">

                                <h3 class="fw-bold text-danger">

                                    @Model.FailureRate%

                                </h3>

                                <small class="text-muted">

                                    Failure Rate

                                </small>

                            </div>

                        </div>

                    </div>

                    <div class="mb-3">

                        <p class="text-muted mb-1">

                            Average Payment

                        </p>

                        <h5 class="fw-bold">

                            ₹@Model.AveragePaymentAmount.ToString("0.00")

                        </h5>

                    </div>

                    <div>

                        <p class="text-muted mb-1">

                            Top Paying Route

                        </p>

                        <h5 class="fw-bold text-primary">

                            @Model.TopPayingRoute

                        </h5>

                    </div>

                </div>

            </div>

        </div>

    </div>


    <!-- OFFICES -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="fw-bold text-primary mb-0">

            Offices

        </h3>

    </div>

    <div class="row g-4">

        @foreach (var office in Model.Offices)
        {
            <div class="col-lg-4 col-md-6">

                <div class="card shadow-sm border-0 rounded-4 h-100">

                    <div class="card-body d-flex flex-column">

                        <div class="mb-3">

                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <h5 class="fw-bold mb-0">

                                    Office #@office.OfficeId

                                </h5>

                                <span class="badge bg-primary">

                                    Active

                                </span>

                            </div>

                            <p class="mb-2">

                                <i class="bi bi-envelope me-2 text-primary"></i>

                                @office.OfficeMail

                            </p>

                            <p class="mb-2">

                                <i class="bi bi-person me-2 text-success"></i>

                                @office.OfficeContactPersonName

                            </p>

                            <p class="mb-0">

                                <i class="bi bi-telephone me-2 text-danger"></i>

                                @office.OfficeContactNumber

                            </p>

                        </div>

                        <div class="mt-auto">

                            <a asp-controller="AgencyOffice"
                                   asp-action="Details"
                                   asp-route-officeId="@office.OfficeId"
                                   class="btn btn-primary w-100 rounded-3">

                                <i class="bi bi-eye me-1"></i>

                                View Office

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>