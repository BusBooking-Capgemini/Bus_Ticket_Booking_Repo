@{
    ViewData["Title"] = "Office Dashboard";
}

<div class="container py-5">

    <div class="row">

        <div class="col-md-12">

            <div class="card custom-card p-5 shadow-sm border-0">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h1 class="text-success fw-bold">

                            Office Dashboard

                        </h1>

                        <p class="text-muted mt-2 mb-0">

                            Welcome @ViewBag.Email

                        </p>

                    </div>

                    <div>

                        <span class="badge bg-success p-3">

                            Office Panel

                        </span>

                    </div>

                </div>

                <hr class="my-4" />

                <div class="row mt-2">

                    <!-- MANAGE TRIPS -->

                    <div class="col-md-4 mb-4">

                        <a asp-controller="OfficeTrip"
                               asp-action="Index"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100
                                dashboard-card">

                                <div class="card-body text-center p-4">

                                    <i class="bi bi-signpost-2
                                        display-4 text-primary">
                                    </i>

                                    <h4 class="mt-3 text-dark fw-bold">

                                        Manage Trips

                                    </h4>

                                    <p class="text-muted mb-0">

                                        Create, edit and manage trips

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- MANAGE BUSES -->

                    <div class="col-md-4 mb-4">

                        <a asp-controller="OfficeBus"
                               asp-action="Index"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100
                                dashboard-card">

                                <div class="card-body text-center p-4">

                                    <i class="bi bi-bus-front
                                        display-4 text-danger">
                                    </i>

                                    <h4 class="mt-3 text-dark fw-bold">

                                        Manage Buses

                                    </h4>

                                    <p class="text-muted mb-0">

                                        Create, edit and manage buses

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- MANAGE DRIVERS -->

                    <div class="col-md-4 mb-4">

                        <a asp-controller="OfficeDriver"
                               asp-action="Index"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100
                                dashboard-card">

                                <div class="card-body text-center p-4">

                                    <i class="bi bi-person-badge
                                        display-4 text-warning">
                                    </i>

                                    <h4 class="mt-3 text-dark fw-bold">

                                        Manage Drivers

                                    </h4>

                                    <p class="text-muted mb-0">

                                        Create, edit and manage drivers

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- BOOKINGS -->

                    <div class="col-md-4 mb-4">

                        <a asp-controller="OfficeBooking"
                               asp-action="Index"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100
                                dashboard-card">

                                <div class="card-body text-center p-4">

                                    <i class="bi bi-ticket-perforated
                                        display-4 text-success">
                                    </i>

                                    <h4 class="mt-3 text-dark fw-bold">

                                        Bookings

                                    </h4>

                                    <p class="text-muted mb-0">

                                        View all bookings

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- PAYMENTS -->

                    <div class="col-md-4 mb-4">

                        <a asp-controller="OfficePayment"
                               asp-action="Index"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100
                                dashboard-card">

                                <div class="card-body text-center p-4">

                                    <i class="bi bi-credit-card
                                        display-4 text-info">
                                    </i>

                                    <h4 class="mt-3 text-dark fw-bold">

                                        Payments

                                    </h4>

                                    <p class="text-muted mb-0">

                                        View payment history

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>


                    <!-- ANALYTICS -->

                    <div class="col-md-4 mb-4">

                        <a asp-controller="OfficeDashboard"
                               asp-action="Index"
                               class="text-decoration-none">

                            <div class="card
                                shadow-sm
                                border-0
                                h-100
                                dashboard-card">

                                <div class="card-body text-center p-4">

                                    <i class="bi bi-bar-chart-line
                                        display-4 text-secondary">
                                    </i>

                                    <h4 class="mt-3 text-dark fw-bold">

                                        Analytics

                                    </h4>

                                    <p class="text-muted mb-0">

                                        Revenue and booking analytics

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .dashboard-card {
        transition: all 0.3s ease;
        border-radius: 15px;
    }

    .dashboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

</style>