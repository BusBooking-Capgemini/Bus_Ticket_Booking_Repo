﻿@using Bus_Ticket_Booking.Mvc.Helpers

@{
    var token = Context.Session.GetString(SessionKeys.Token);
    var role = Context.Session.GetString(SessionKeys.Role);
    var email = Context.Session.GetString(SessionKeys.Email);
}

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top border-bottom border-secondary">

    <div class="container-fluid px-4">

        <!-- LOGO -->

        <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2"
           asp-controller="Home"
           asp-action="Index">

            <i class="bi bi-bus-front-fill text-warning"></i>

            <span>
                Bus Ticket Booking
            </span>

        </a>

        <!-- MOBILE BUTTON -->

        <button class="navbar-toggler border-0 shadow-none"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContent">

            <span class="navbar-toggler-icon"></span>

        </button>

        <!-- NAVBAR CONTENT -->

        <div class="collapse navbar-collapse"
             id="navbarContent">

            <!-- LEFT MENU -->

            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-lg-2">

                @* =========================
                   CUSTOMER NAVBAR
                   ========================= *@

                @if (!string.IsNullOrEmpty(token) && role == "Customer")
                {
                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Customer"
                           asp-action="Dashboard">

                            <i class="bi bi-speedometer2 me-1"></i>

                            Dashboard

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Trip"
                           asp-action="Index">

                            <i class="bi bi-signpost-split me-1"></i>

                            Trips

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Booking"
                           asp-action="MyBookings">

                            <i class="bi bi-ticket-perforated me-1"></i>

                            My Bookings

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Payment"
                           asp-action="MyPayments">

                            <i class="bi bi-credit-card me-1"></i>

                            Payments

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Review"
                           asp-action="MyReviews">

                            <i class="bi bi-star me-1"></i>

                            My Reviews

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Customer"
                           asp-action="Profile">

                            <i class="bi bi-person-circle me-1"></i>

                            Profile

                        </a>

                    </li>
                }

                @* =========================
                   OFFICE NAVBAR
                   ========================= *@

                @if (!string.IsNullOrEmpty(token) && role == "Office")
                {
                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Office"
                           asp-action="Dashboard">

                            <i class="bi bi-speedometer2 me-1"></i>

                            Dashboard

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="OfficeTrip"
                           asp-action="Index">

                            <i class="bi bi-signpost-split me-1"></i>

                            Trips

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="OfficeBus"
                           asp-action="Index">

                            <i class="bi bi-bus-front me-1"></i>

                            Buses

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="OfficeDriver"
                           asp-action="Index">

                            <i class="bi bi-person-badge me-1"></i>

                            Drivers

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="OfficeBooking"
                           asp-action="Index">

                            <i class="bi bi-ticket-perforated me-1"></i>

                            Bookings

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="OfficePayment"
                           asp-action="Index">

                            <i class="bi bi-credit-card me-1"></i>

                            Payments

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="OfficeDashboard"
                           asp-action="Index">

                            <i class="bi bi-bar-chart-line me-1"></i>

                            Analytics

                        </a>

                    </li>
                }

            </ul>

            <!-- RIGHT MENU -->

            <ul class="navbar-nav align-items-lg-center gap-lg-2">

                @if (string.IsNullOrEmpty(token))
                {
                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Auth"
                           asp-action="Login">

                            Customer Login

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Auth"
                           asp-action="Register">

                            Register

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Auth"
                           asp-action="OfficeLogin">

                            Office Login

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3 rounded-3"
                           asp-controller="Auth"
                           asp-action="AgencyLogin">

                            Agency Login

                        </a>

                    </li>
                }
                else
                {
                    <li class="nav-item">

                        <span class="nav-link text-info fw-semibold">

                            <i class="bi bi-person-circle me-1"></i>

                            @email

                        </span>

                    </li>

                    <li class="nav-item">

                        <a class="btn btn-danger btn-sm px-3 rounded-3"
                           asp-controller="Auth"
                           asp-action="Logout">

                            <i class="bi bi-box-arrow-right me-1"></i>

                            Logout

                        </a>

                    </li>
                }

            </ul>

        </div>

    </div>

</nav>

<style>

    .navbar .nav-link {
        transition: all 0.2s ease;
        font-weight: 500;
    }

        .navbar .nav-link:hover {
            background-color: rgba(255,255,255,0.08);
            color: #fff !important;
        }

        .navbar .nav-link.active {
            background-color: #0d6efd;
            color: white !important;
        }

</style>