@model Bus_Ticket_Booking.Mvc.ViewModels.OfficeDashboard.OfficeDashboardViewModel

@{
    ViewData["Title"] = "Office Dashboard";
}

<div class="container-fluid py-4 px-4 bg-light">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-dark mb-1">
                Office Dashboard
            </h2>

            <p class="text-muted mb-0">
                Analytics and performance overview
            </p>

        </div>

    </div>


    <!-- TOP STATS -->

    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Total Buses
                            </p>

                            <h2 class="fw-bold text-primary mb-0">
                                @Model.TotalBuses
                            </h2>

                        </div>

                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-bus-front text-primary fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Total Drivers
                            </p>

                            <h2 class="fw-bold text-success mb-0">
                                @Model.TotalDrivers
                            </h2>

                        </div>

                        <div class="bg-success bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-person-badge text-success fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Total Bookings
                            </p>

                            <h2 class="fw-bold text-dark mb-0">
                                @Model.TotalBookings
                            </h2>

                        </div>

                        <div class="bg-dark bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-ticket-perforated text-dark fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Revenue
                            </p>

                            <h2 class="fw-bold text-danger mb-0">
                                ₹@Model.TotalRevenue
                            </h2>

                        </div>

                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-currency-rupee text-danger fs-3"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>



    <!-- ANALYTICS -->

    <div class="row g-4">

        <!-- BOOKING ANALYTICS -->

        <div class="col-lg-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <h5 class="fw-bold mb-0">
                            Booking Analytics
                        </h5>

                        <i class="bi bi-bar-chart-line text-primary fs-4"></i>

                    </div>

                    <div class="mb-4">

                        <div class="d-flex justify-content-between mb-2">

                            <span class="fw-semibold">
                                Occupancy Rate
                            </span>

                            <span class="fw-bold text-primary">
                                @Model.OccupancyRate%
                            </span>

                        </div>

                        <div class="progress" style="height:10px;">

                            <div class="progress-bar bg-primary"
                                 style="width:@Model.OccupancyRate%">
                            </div>

                        </div>

                    </div>

                    <div class="mb-3">

                        <p class="text-muted mb-1">
                            Most Booked Trip
                        </p>

                        <h6 class="fw-bold">
                            Trip #@Model.MostBookedTripId
                        </h6>

                    </div>

                    <div>

                        <p class="text-muted mb-1">
                            Most Popular Route
                        </p>

                        <h6 class="fw-bold text-success">
                            @Model.MostPopularRoute
                        </h6>

                    </div>

                </div>

            </div>

        </div>


        <!-- PAYMENT ANALYTICS -->

        <div class="col-lg-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <h5 class="fw-bold mb-0">
                            Payment Analytics
                        </h5>

                        <i class="bi bi-credit-card text-success fs-4"></i>

                    </div>

                    <div class="row mb-4">

                        <div class="col-6">

                            <div class="bg-success bg-opacity-10 rounded-4 p-3 text-center">

                                <h3 class="fw-bold text-success">
                                    @Model.SuccessRate%
                                </h3>

                                <small class="text-muted">
                                    Success Rate
                                </small>

                            </div>

                        </div>

                        <div class="col-6">

                            <div class="bg-danger bg-opacity-10 rounded-4 p-3 text-center">

                                <h3 class="fw-bold text-danger">
                                    @Model.FailureRate%
                                </h3>

                                <small class="text-muted">
                                    Failure Rate
                                </small>

                            </div>

                        </div>

                    </div>

                    <div class="mb-3">

                        <p class="text-muted mb-1">
                            Average Payment
                        </p>

                        <h5 class="fw-bold">
                            ₹@Model.AveragePaymentAmount.ToString("0.00")
                        </h5>

                    </div>

                    <div>

                        <p class="text-muted mb-1">
                            Top Paying Route
                        </p>

                        <h6 class="fw-bold text-primary">
                            @Model.TopPayingRoute
                        </h6>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>