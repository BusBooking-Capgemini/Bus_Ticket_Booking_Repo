@model Bus_Ticket_Booking.Mvc.ViewModels.Driver.CreateDriverViewModel

@{
    ViewData["Title"] = "Create Driver";
}

<div class="container py-5">

    <div class="card shadow-sm border-0">

        <div class="card-body p-5">

            <h2 class="text-primary mb-4">

                Create Driver

            </h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">

                    @ViewBag.Error

                </div>
            }

            <form asp-action="Create"
                  method="post">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Driver Name

                        </label>

                        <input asp-for="Name"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            License Number

                        </label>

                        <input asp-for="LicenseNumber"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Phone

                        </label>

                        <input asp-for="Phone"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Address

                        </label>

                        <input asp-for="Address"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">

                            City

                        </label>

                        <input asp-for="City"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">

                            State

                        </label>

                        <input asp-for="State"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">

                            Zip Code

                        </label>

                        <input asp-for="ZipCode"
                               class="form-control" />

                    </div>

                </div>

                <button type="submit"
                        class="btn btn-success w-100 mt-3">

                    Create Driver

                </button>

            </form>

        </div>

    </div>

</div>