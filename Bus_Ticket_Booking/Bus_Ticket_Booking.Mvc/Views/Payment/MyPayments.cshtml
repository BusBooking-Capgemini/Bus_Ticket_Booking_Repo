@model List<Bus_Ticket_Booking.Mvc.ViewModels.Payment.PaymentListViewModel>

@{
    ViewData["Title"] = "My Payments";
}

<div class="container py-4">

    <!-- HEADER -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-success mb-1">

                My Payments

            </h2>

            <p class="text-muted mb-0">

                View all your payment transactions

            </p>

        </div>

        <div class="bg-success bg-opacity-10 p-3 rounded-circle">

            <i class="bi bi-credit-card text-success fs-4"></i>

        </div>

    </div>


    <!-- PAYMENT TABLE -->

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">

                        <tr>

                            <th>Payment ID</th>
                            <th>Booking ID</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Date</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            @foreach (var payment in Model)
                            {
                                <tr>

                                    <td class="fw-semibold">

                                        #@payment.PaymentId

                                    </td>

                                    <td>

                                        #@payment.BookingId

                                    </td>

                                    <td class="fw-bold text-success">

                                        ₹@payment.Amount

                                    </td>

                                    <td>

                                        @if (payment.Status == "Success")
                                        {
                                            <span class="badge bg-success px-3 py-2">

                                                Success

                                            </span>
                                        }
                                        else if (payment.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2">

                                                Pending

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2">

                                                Failed

                                            </span>
                                        }

                                    </td>

                                    <td class="text-muted">

                                        @payment.PaymentDate.ToString("dd MMM yyyy")

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="5"
                                    class="text-center py-5 text-muted">

                                    <i class="bi bi-credit-card fs-1 d-block mb-3"></i>

                                    No payments found.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>