@model CreateTripViewModel
<h1 class="h4 mb-3">@ViewData["Title"]</h1>
<form method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row">
            <div class="col-md-6 mb-3"><label asp-for="RouteId" class="form-label"></label><select asp-for="RouteId" asp-items="ViewBag.Routes" class="form-select"><option value="">Select route</option></select><span asp-validation-for="RouteId"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="BusId" class="form-label"></label><select asp-for="BusId" asp-items="ViewBag.Buses" class="form-select"><option value="">Select bus</option></select><span asp-validation-for="BusId"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="BoardingAddressId" class="form-label"></label><input asp-for="BoardingAddressId" class="form-control" /><span asp-validation-for="BoardingAddressId"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="DroppingAddressId" class="form-label"></label><input asp-for="DroppingAddressId" class="form-control" /><span asp-validation-for="DroppingAddressId"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="DepartureTime" class="form-label"></label><input asp-for="DepartureTime" class="form-control" /><span asp-validation-for="DepartureTime"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="ArrivalTime" class="form-label"></label><input asp-for="ArrivalTime" class="form-control" /><span asp-validation-for="ArrivalTime"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="Driver1DriverId" class="form-label"></label><select asp-for="Driver1DriverId" asp-items="ViewBag.Drivers" class="form-select"><option value="">Select primary driver</option></select><span asp-validation-for="Driver1DriverId"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="Driver2DriverId" class="form-label"></label><select asp-for="Driver2DriverId" asp-items="ViewBag.Drivers" class="form-select"><option value="">Select secondary driver</option></select><span asp-validation-for="Driver2DriverId"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="Fare" class="form-label"></label><input asp-for="Fare" class="form-control" /><span asp-validation-for="Fare"></span></div>
            <div class="col-md-6 mb-3"><label asp-for="TripDate" class="form-label"></label><input asp-for="TripDate" class="form-control" /><span asp-validation-for="TripDate"></span></div>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
