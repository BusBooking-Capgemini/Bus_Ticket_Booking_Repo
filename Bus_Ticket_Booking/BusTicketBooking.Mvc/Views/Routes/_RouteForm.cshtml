@model CreateRouteViewModel
<h1 class="h4 mb-3">@ViewData["Title"]</h1>
<form method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3"><label asp-for="FromCity" class="form-label"></label><input asp-for="FromCity" class="form-control" /><span asp-validation-for="FromCity"></span></div>
        <div class="mb-3"><label asp-for="ToCity" class="form-label"></label><input asp-for="ToCity" class="form-control" /><span asp-validation-for="ToCity"></span></div>
        <div class="mb-3"><label asp-for="BreakPoints" class="form-label"></label><input asp-for="BreakPoints" class="form-control" /><span asp-validation-for="BreakPoints"></span></div>
        <div class="mb-3"><label asp-for="Duration" class="form-label"></label><input asp-for="Duration" class="form-control" /><span asp-validation-for="Duration"></span></div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
