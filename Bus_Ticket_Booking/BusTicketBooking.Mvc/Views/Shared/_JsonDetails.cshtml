@using BusTicketBooking.Mvc.Helpers
@model System.Text.Json.JsonElement

@if (Model.ValueKind == System.Text.Json.JsonValueKind.Object)
{
    <dl class="row">
        @foreach (var item in Model.EnumerateObject())
        {
            <dt class="col-sm-3">@item.Name</dt>
            <dd class="col-sm-9">@JsonDisplayHelper.ToDisplay(item.Value)</dd>
        }
    </dl>
}
else
{
    <partial name="_JsonTable" model="Model" />
}
