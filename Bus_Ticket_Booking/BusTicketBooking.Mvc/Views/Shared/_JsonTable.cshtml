@using BusTicketBooking.Mvc.Helpers
@model System.Text.Json.JsonElement
@{
    var columns = JsonDisplayHelper.GetColumns(Model);
    var rows = JsonDisplayHelper.GetRows(Model);
}

@if (rows.Count == 0)
{
    <p class="text-muted">No records returned.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle">
            <thead>
                <tr>
                    @foreach (var column in columns)
                    {
                        <th>@column</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        @foreach (var column in columns)
                        {
                            <td>@JsonDisplayHelper.GetValue(row, column)</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
