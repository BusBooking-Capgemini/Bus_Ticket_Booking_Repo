@model ApiJsonViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">@Model.Title</h1>
    @if (!string.IsNullOrWhiteSpace(Model.CreateAction))
    {
        <a class="btn btn-primary btn-sm" asp-controller="@Model.ControllerName" asp-action="@Model.CreateAction">Create</a>
    }
</div>
<partial name="_ApiMessages" model="Model" />
@if (Model.Result.Succeeded)
{
    <partial name="_JsonTable" model="Model.Result.Data" />
}
