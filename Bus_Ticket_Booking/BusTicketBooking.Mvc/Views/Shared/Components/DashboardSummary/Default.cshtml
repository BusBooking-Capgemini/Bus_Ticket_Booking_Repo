@model IEnumerable<DashboardMetric>

<div class="row g-3 mb-4">
    @foreach (var metric in Model)
    {
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted small">@metric.Label</div>
                    <div class="h5 mb-0">@metric.Value</div>
                </div>
            </div>
        </div>
    }
</div>
