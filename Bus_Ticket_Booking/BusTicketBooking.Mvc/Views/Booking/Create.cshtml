@model CreateBookingViewModel
@{
    ViewData["Title"] = "Create Booking";
}
<h1 class="h4 mb-3">Create Booking</h1>
<form asp-controller="Booking" asp-action="Create" method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3"><label asp-for="TripId" class="form-label"></label><input asp-for="TripId" class="form-control" /><span asp-validation-for="TripId"></span></div>
        <div class="mb-3"><label asp-for="SeatNumber" class="form-label"></label><input asp-for="SeatNumber" class="form-control" /><span asp-validation-for="SeatNumber"></span></div>
        <button type="submit" class="btn btn-primary">Book</button>
    </div>
</form>
