@model BusRequestViewModel
<h1 class="h4 mb-3">@ViewData["Title"]</h1>
<form method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3"><label asp-for="OfficeId" class="form-label"></label><input asp-for="OfficeId" class="form-control" /><span asp-validation-for="OfficeId"></span></div>
        <div class="mb-3"><label asp-for="RegistrationNumber" class="form-label"></label><input asp-for="RegistrationNumber" class="form-control" /><span asp-validation-for="RegistrationNumber"></span></div>
        <div class="mb-3"><label asp-for="Capacity" class="form-label"></label><input asp-for="Capacity" class="form-control" /><span asp-validation-for="Capacity"></span></div>
        <div class="mb-3"><label asp-for="Type" class="form-label"></label><input asp-for="Type" class="form-control" /><span asp-validation-for="Type"></span></div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
