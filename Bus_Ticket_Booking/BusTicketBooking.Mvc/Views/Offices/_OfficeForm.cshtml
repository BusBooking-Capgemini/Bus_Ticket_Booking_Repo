@model OfficeRequestViewModel
<h1 class="h4 mb-3">@ViewData["Title"]</h1>
<form method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3"><label asp-for="AgencyId" class="form-label"></label><input asp-for="AgencyId" class="form-control" /><span asp-validation-for="AgencyId"></span></div>
        <div class="mb-3"><label asp-for="OfficeMail" class="form-label"></label><input asp-for="OfficeMail" class="form-control" /><span asp-validation-for="OfficeMail"></span></div>
        <div class="mb-3"><label asp-for="OfficeContactPersonName" class="form-label"></label><input asp-for="OfficeContactPersonName" class="form-control" /><span asp-validation-for="OfficeContactPersonName"></span></div>
        <div class="mb-3"><label asp-for="OfficeContactNumber" class="form-label"></label><input asp-for="OfficeContactNumber" class="form-control" /><span asp-validation-for="OfficeContactNumber"></span></div>
        <div class="mb-3"><label asp-for="OfficeAddressId" class="form-label"></label><input asp-for="OfficeAddressId" class="form-control" /><span asp-validation-for="OfficeAddressId"></span></div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
