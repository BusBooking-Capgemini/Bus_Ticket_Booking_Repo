@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h4 mb-3">Login</h1>
        <form asp-controller="Auth" asp-action="Login" method="post" class="card">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select">
                        <option>Customer</option>
                        <option>Agency</option>
                        <option>Office</option>
                    </select>
                    <span asp-validation-for="Role"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password"></span>
                </div>
                <button type="submit" class="btn btn-primary">Login</button>
            </div>
        </form>
        <div class="mt-3 d-flex gap-3">
            <a asp-controller="Auth" asp-action="CustomerRegister">Customer register</a>
            <a asp-controller="Auth" asp-action="OfficeRegister">Office register</a>
            <a asp-controller="Auth" asp-action="AgencyRegister">Agency register</a>
        </div>
    </div>
</div>
